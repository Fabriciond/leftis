---
import { asset } from "../utils/base";

const year = new Date().getFullYear();
---

<footer
  class="border-t border-[#32353c]/20 bg-[#0b0e14] px-4 pb-10 pt-16 sm:px-8"
>
  <div
    class="section-inner mx-auto flex max-w-7xl flex-col items-center justify-between gap-8 md:flex-row md:items-start"
  >
    <div class="space-y-4 text-center md:text-left">
      <a
        href="#main-content"
        class="inline-flex items-center gap-3 text-lg font-bold text-[#b3c5ff] no-underline transition hover:opacity-90 md:justify-start"
      >
        <img
          src={asset("img/logo.png")}
          width="48"
          height="48"
          class="h-11 w-11 shrink-0 object-contain"
          alt=""
          aria-hidden="true"
        />
        <span>Leftis Systems</span>
      </a>
      <p class="text-sm text-[#99cdf3]">
        © {year} Leftis Systems. The Digital Architect.
      </p>
    </div>
    <nav aria-label="Pie de página">
      <ul
        class="flex list-none flex-col items-center gap-3 md:flex-row md:gap-8"
      >
        <li>
          <a
            href="#main-content"
            class="text-sm text-[#99cdf3] no-underline transition hover:text-[#b3c5ff]"
            >Inicio</a
          >
        </li>
        <li>
          <a
            href="#services"
            class="text-sm text-[#99cdf3] no-underline transition hover:text-[#b3c5ff]"
            >Servicios</a
          >
        </li>
        <li>
          <a
            href="#planes"
            class="text-sm text-[#99cdf3] no-underline transition hover:text-[#b3c5ff]"
            >Planes</a
          >
        </li>
        <li>
          <a
            href="#contact"
            class="text-sm text-[#99cdf3] no-underline transition hover:text-[#b3c5ff]"
            >Contacto</a
          >
        </li>
      </ul>
    </nav>
    <div class="flex flex-wrap items-center justify-center gap-6">
      <a
        href="https://www.facebook.com/people/Leftis-Systems/61553649370854/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-[#99cdf3] no-underline transition hover:text-[#b3c5ff]"
        >Facebook</a
      >
      <a
        href="https://www.instagram.com/leftissystem/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-[#99cdf3] no-underline transition hover:text-[#b3c5ff]"
        >Instagram</a
      >
    </div>
  </div>
</footer>
