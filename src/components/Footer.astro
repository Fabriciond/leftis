---
import { asset } from "../utils/base";

const year = new Date().getFullYear();
---

<footer
  class="mt-16 border-t border-primary/30 bg-secondary/95 px-4 py-10 text-primary sm:px-8"
>
  <div
    class="section-inner flex flex-col items-center justify-between gap-8 md:flex-row md:items-start"
  >
    <div class="flex flex-col items-center gap-3 md:items-start">
      <img
        src={asset("img/logo-invert.png")}
        alt="Leftis"
        width="120"
        height="48"
        class="h-10 w-auto object-contain"
        loading="lazy"
        decoding="async"
      />
      <p class="text-center text-sm text-primary/80 md:text-left">
        © {year} Leftis. Todos los derechos reservados.
      </p>
    </div>
    <nav aria-label="Pie de página">
      <ul
        class="flex list-none flex-col items-center gap-3 md:flex-row md:gap-8"
      >
        <li>
          <a
            href="#main-content"
            class="text-base font-medium text-primary no-underline transition hover:underline"
            >Inicio</a>
        </li>
        <li>
          <a
            href="#services"
            class="text-base font-medium text-primary no-underline transition hover:underline"
            >Servicios</a>
        </li>
        <li>
          <a
            href="#contact"
            class="text-base font-medium text-primary no-underline transition hover:underline"
            >Contacto</a>
        </li>
      </ul>
    </nav>
    <div class="flex flex-row items-center gap-6">
      <ul class="flex list-none flex-row gap-6">
        <li>
          <a
            href="https://www.facebook.com/people/Leftis-Systems/61553649370854/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook de Leftis"
            class="inline-flex rounded-lg p-1 transition hover:opacity-80"
          >
            <img
              src={asset("img/facebook.png")}
              alt=""
              width="30"
              height="30"
              class="h-8 w-8 object-contain"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            />
          </a>
        </li>
        <li>
          <a
            href="https://www.instagram.com/leftissystem/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram de Leftis"
            class="inline-flex rounded-lg p-1 transition hover:opacity-80"
          >
            <img
              src={asset("img/instagram.png")}
              alt=""
              width="30"
              height="30"
              class="h-8 w-8 object-contain"
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            />
          </a>
        </li>
      </ul>
    </div>
  </div>
</footer>
