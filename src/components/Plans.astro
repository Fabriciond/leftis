---
import { CircleCheck } from "@lucide/astro";
---

<section
  id="planes"
  class="scroll-mt-28 bg-[#0b0e14] py-24 sm:py-32"
  aria-labelledby="plans-heading"
>
  <div class="section-inner max-w-7xl">
    <div class="mb-16 space-y-4 text-center md:mb-20" data-aos="fade-up">
      <span
        class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-[#b3c5ff]"
      >
        Inversión inteligente
      </span>
      <h2
        id="plans-heading"
        class="text-4xl font-bold tracking-tighter text-[#e1e2eb] md:text-5xl"
      >
        Planes que escalan contigo
      </h2>
    </div>
    <div
      class="grid grid-cols-1 items-stretch gap-8 lg:grid-cols-3 lg:gap-8"
    >
      <article
        data-aos="fade-up"
        class="flex flex-col justify-between rounded-xl border border-[#424656]/10 bg-[#10131a] p-10"
      >
        <div>
          <h3 class="mb-2 text-2xl font-bold text-[#e1e2eb]">Emprendedor</h3>
          <div class="mb-6 font-black text-[#b3c5ff]">
            <span class="text-4xl">Desde $2,499</span>
            <span class="text-sm font-normal text-[#c2c6d8]"> MXN</span>
          </div>
          <p class="mb-6 text-sm leading-relaxed text-[#c2c6d8]">
            Landing page estática para dar a conocer tu negocio, productos o
            servicios.
          </p>
          <ul class="mb-10 space-y-4">
            <li class="flex items-center gap-3 text-[#c2c6d8]">
              <CircleCheck class="shrink-0 text-[#b3c5ff]" size={20} aria-hidden="true" />
              Diseño personalizado
            </li>
            <li class="flex items-center gap-3 text-[#c2c6d8]">
              <CircleCheck class="shrink-0 text-[#b3c5ff]" size={20} aria-hidden="true" />
              Secciones: Inicio, Sobre nosotros, Servicios, Contacto
            </li>
            <li class="flex items-center gap-3 text-[#c2c6d8]">
              <CircleCheck class="shrink-0 text-[#b3c5ff]" size={20} aria-hidden="true" />
              SEO básico y diseño responsive
            </li>
            <li class="flex items-center gap-3 text-[#c2c6d8]">
              <CircleCheck class="shrink-0 text-[#b3c5ff]" size={20} aria-hidden="true" />
              Hosting incluido
            </li>
          </ul>
        </div>
        <a
          href="#contact"
          class="block w-full rounded-xl border border-[#b3c5ff] py-4 text-center text-base font-bold text-[#b3c5ff] no-underline transition hover:bg-[#b3c5ff]/5"
          >Seleccionar</a
        >
      </article>

      <article
        data-aos="fade-up"
        data-aos-delay="80"
        class="relative z-10 flex flex-col justify-between rounded-xl border border-[#0066ff]/30 bg-[#272a31] p-10 shadow-2xl shadow-[#0066ff]/10 lg:scale-[1.02]"
      >
        <div
          class="absolute -top-4 left-1/2 -translate-x-1/2 rounded-full bg-[#0066ff] px-4 py-1 text-xs font-bold uppercase tracking-widest text-[#f8f7ff]"
        >
          Más popular
        </div>
        <div>
          <h3 class="mb-2 mt-2 text-2xl font-bold text-[#e1e2eb]">PyME</h3>
          <div class="mb-6 font-black text-[#b3c5ff]">
            <span class="text-4xl">Desde $9,999</span>
            <span class="text-sm font-normal text-[#c2c6d8]"> MXN</span>
          </div>
          <p class="mb-6 text-sm leading-relaxed text-[#e1e2eb]/90">
            Inventario, ventas, clientes y procesos adaptados a tu operación.
          </p>
          <ul class="mb-10 space-y-4">
            <li class="flex items-center gap-3 text-[#e1e2eb]">
              <CircleCheck class="shrink-0 text-[#b3c5ff]" size={20} aria-hidden="true" />
              Diseño de sistemas personalizados
            </li>
            <li class="flex items-center gap-3 text-[#e1e2eb]">
              <CircleCheck class="shrink-0 text-[#b3c5ff]" size={20} aria-hidden="true" />
              Integración con herramientas existentes (si aplica)
            </li>
            <li class="flex items-center gap-3 text-[#e1e2eb]">
              <CircleCheck class="shrink-0 text-[#b3c5ff]" size={20} aria-hidden="true" />
              Capacitación
            </li>
            <li class="flex items-center gap-3 text-[#e1e2eb]">
              <CircleCheck class="shrink-0 text-[#b3c5ff]" size={20} aria-hidden="true" />
              Hosting incluido
            </li>
          </ul>
        </div>
        <a
          href="#contact"
          class="block w-full rounded-xl bg-[#0066ff] py-4 text-center text-base font-bold text-[#f8f7ff] no-underline shadow-lg shadow-[#0066ff]/20 transition hover:opacity-90"
          >Seleccionar</a
        >
      </article>

      <article
        data-aos="fade-up"
        data-aos-delay="160"
        class="flex flex-col justify-between rounded-xl border border-[#424656]/10 bg-[#10131a] p-10"
      >
        <div>
          <h3 class="mb-2 text-2xl font-bold text-[#e1e2eb]">Empresarial</h3>
          <div class="mb-6 font-black text-[#b3c5ff]">
            <span class="text-4xl">Desde $14,999</span>
            <span class="text-sm font-normal text-[#c2c6d8]"> MXN</span>
          </div>
          <p class="mb-6 text-sm leading-relaxed text-[#c2c6d8]">
            Software a la medida con análisis, consultoría y pruebas
            exhaustivas.
          </p>
          <ul class="mb-10 space-y-4">
            <li class="flex items-center gap-3 text-[#c2c6d8]">
              <CircleCheck class="shrink-0 text-[#b3c5ff]" size={20} aria-hidden="true" />
              Análisis y desarrollo a medida
            </li>
            <li class="flex items-center gap-3 text-[#c2c6d8]">
              <CircleCheck class="shrink-0 text-[#b3c5ff]" size={20} aria-hidden="true" />
              Consultoría en necesidades y soluciones
            </li>
            <li class="flex items-center gap-3 text-[#c2c6d8]">
              <CircleCheck class="shrink-0 text-[#b3c5ff]" size={20} aria-hidden="true" />
              Implementación, pruebas y responsive
            </li>
            <li class="flex items-center gap-3 text-[#c2c6d8]">
              <CircleCheck class="shrink-0 text-[#b3c5ff]" size={20} aria-hidden="true" />
              Opcional: landing de presentación · hosting incluido
            </li>
          </ul>
        </div>
        <a
          href="#contact"
          class="block w-full rounded-xl border border-[#b3c5ff] py-4 text-center text-base font-bold text-[#b3c5ff] no-underline transition hover:bg-[#b3c5ff]/5"
          >Seleccionar</a
        >
      </article>
    </div>
  </div>
</section>
