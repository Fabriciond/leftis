---
import { Terminal, MousePointerClick, ChartLine } from "@lucide/astro";
---

<section
  id="services"
  class="scroll-mt-28 bg-[#10131a] py-24 sm:py-32"
  aria-labelledby="services-heading"
>
  <div class="section-inner max-w-7xl">
    <div class="mb-16 space-y-4 md:mb-20" data-aos="fade-up">
      <h2
        id="services-heading"
        class="text-3xl font-bold tracking-tighter text-[#e1e2eb] md:text-5xl"
      >
        Nuestros servicios
      </h2>
      <div class="h-1 w-20 rounded-full bg-[#0066ff]"></div>
    </div>
    <div
      class="grid grid-cols-1 gap-8 md:grid-cols-3 md:gap-8 lg:gap-10"
    >
      <article
        data-aos="fade-right"
        class="group rounded-xl bg-[#191c22] p-10 transition-all duration-500 hover:-translate-y-2 hover:bg-[#272a31]"
      >
        <div
          class="mb-8 flex h-16 w-16 items-center justify-center rounded-full bg-[#0e4e6f] transition-transform duration-500 group-hover:scale-110"
        >
          <Terminal
            class="text-[#b3c5ff]"
            size={32}
            stroke-width={1.75}
            aria-hidden="true"
          />
        </div>
        <h3 class="mb-4 text-xl font-bold text-[#e1e2eb]">Desarrollo web</h3>
        <p class="leading-relaxed text-[#c2c6d8]">
          Plataformas robustas, escalables y optimizadas para SEO, construidas
          con las tecnologías más modernas del ecosistema actual.
        </p>
      </article>
      <article
        data-aos="fade-up"
        class="group rounded-xl bg-[#191c22] p-10 transition-all duration-500 hover:-translate-y-2 hover:bg-[#272a31]"
      >
        <div
          class="mb-8 flex h-16 w-16 items-center justify-center rounded-full bg-[#0e4e6f] transition-transform duration-500 group-hover:scale-110"
        >
          <MousePointerClick
            class="text-[#b3c5ff]"
            size={32}
            stroke-width={1.75}
            aria-hidden="true"
          />
        </div>
        <h3 class="mb-4 text-xl font-bold text-[#e1e2eb]">Marketing digital</h3>
        <p class="leading-relaxed text-[#c2c6d8]">
          Estrategias de crecimiento basadas en datos, gestión de campañas y
          posicionamiento de marca en canales digitales estratégicos.
        </p>
      </article>
      <article
        data-aos="fade-left"
        class="group rounded-xl bg-[#191c22] p-10 transition-all duration-500 hover:-translate-y-2 hover:bg-[#272a31]"
      >
        <div
          class="mb-8 flex h-16 w-16 items-center justify-center rounded-full bg-[#0e4e6f] transition-transform duration-500 group-hover:scale-110"
        >
          <ChartLine
            class="text-[#b3c5ff]"
            size={32}
            stroke-width={1.75}
            aria-hidden="true"
          />
        </div>
        <h3 class="mb-4 text-xl font-bold text-[#e1e2eb]">Consultoría</h3>
        <p class="leading-relaxed text-[#c2c6d8]">
          Asesoramiento técnico para la transformación digital de procesos,
          selección de stack tecnológico y optimización de flujos de trabajo.
        </p>
      </article>
    </div>
  </div>
</section>
