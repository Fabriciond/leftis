<main
  id="main-content"
  class="scroll-mt-28 relative flex min-h-screen items-center overflow-hidden bg-[#10131a] px-4 pb-16 pt-28 text-[#e1e2eb] sm:px-8 sm:pb-20 sm:pt-32 md:px-12 md:pt-36"
>
  <div
    class="pointer-events-none absolute left-0 top-1/2 -z-10 h-[min(800px,90vw)] w-[min(800px,90vw)] -translate-y-1/2 rounded-full bg-[#0e4e6f]/10 blur-[120px]"
    aria-hidden="true"
  />
  <div
    class="pointer-events-none absolute bottom-0 right-0 -z-10 h-[min(480px,70vw)] w-[min(480px,70vw)] translate-x-1/4 translate-y-1/4 rounded-full bg-[#0066ff]/5 blur-[100px]"
    aria-hidden="true"
  />

  <div
    class="mx-auto grid w-full max-w-7xl items-center gap-12 px-4 sm:px-6 lg:px-8 md:grid-cols-2 md:gap-14 lg:gap-16"
  >
    <div class="space-y-8 text-left">
      <span
        class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-[#b3c5ff]"
      >
        Digital Excellence
      </span>
      <h1
        data-aos="zoom-in"
        class="text-balance text-4xl font-extrabold leading-[1.1] tracking-tighter text-[#e1e2eb] sm:text-5xl md:text-6xl lg:text-7xl"
      >
        Transformamos tu <span
          class="bg-gradient-to-r from-[#b3c5ff] to-[#0066ff] bg-clip-text text-transparent"
          >visión</span
        > en realidad digital
      </h1>
      <p
        class="max-w-xl text-pretty text-lg leading-relaxed text-[#c2c6d8]"
      >
        Arquitectura de software de alto nivel y estrategias de marketing
        impulsadas por datos. Diseñamos el futuro de tu presencia digital con
        precisión técnica y elegancia estética.
      </p>
      <div class="flex flex-wrap gap-4 pt-2">
        <a
          data-aos="flip-up"
          data-aos-delay="100"
          class="inline-flex min-h-[48px] items-center justify-center rounded-xl bg-[#0066ff] px-8 py-4 text-lg font-bold text-[#f8f7ff] no-underline shadow-lg shadow-[#0066ff]/20 transition hover:opacity-95 active:scale-[0.98] focus-visible:outline focus-visible:ring-2 focus-visible:ring-[#b3c5ff] focus-visible:ring-offset-2 focus-visible:ring-offset-[#10131a]"
          href="#contact">Contáctanos</a
        >
        <a
          class="inline-flex min-h-[48px] items-center justify-center rounded-xl border border-[#424656]/40 bg-[#32353c]/30 px-8 py-4 text-lg font-bold text-[#e1e2eb] no-underline backdrop-blur-sm transition hover:bg-[#32353c]/50 active:scale-[0.98] focus-visible:outline focus-visible:ring-2 focus-visible:ring-[#b3c5ff] focus-visible:ring-offset-2 focus-visible:ring-offset-[#10131a]"
          href="#clientes">Ver portafolio</a
        >
      </div>
    </div>

    <div class="relative hidden min-h-[320px] md:block" aria-hidden="true">
      <div
        class="absolute left-1/2 top-1/2 aspect-square w-[min(100%,420px)] -translate-x-1/2 -translate-y-1/2 animate-[spin_20s_linear_infinite] rounded-full border border-[#b3c5ff]/10"
      />
      <div
        class="relative z-10 mx-auto w-full max-w-md rotate-3 transition-transform duration-700 hover:rotate-0"
      >
        <div
          class="overflow-hidden rounded-3xl border border-[#424656]/30 bg-[#1d2026]/90 shadow-2xl shadow-black/50 backdrop-blur-sm"
        >
          <div class="relative aspect-square p-6 sm:p-8">
            <div
              class="absolute inset-0 opacity-[0.35] [background-image:linear-gradient(rgba(179,197,255,0.14)_1px,transparent_1px),linear-gradient(90deg,rgba(179,197,255,0.14)_1px,transparent_1px)] [background-size:28px_28px]"
            />
            <div
              class="absolute inset-0 bg-gradient-to-br from-[#0066ff]/25 via-transparent to-[#0e4e6f]/35"
            />
            <div
              class="absolute left-[12%] top-[18%] h-2 w-2 rounded-full bg-[#b3c5ff] shadow-[0_0_24px_#b3c5ff]"
            />
            <div
              class="absolute right-[20%] top-[32%] h-1.5 w-1.5 rounded-full bg-[#99cdf3] shadow-[0_0_16px_#99cdf3]"
            />
            <div
              class="absolute bottom-[28%] left-[28%] h-2 w-2 rounded-full bg-[#0066ff] shadow-[0_0_20px_#0066ff]"
            />
            <div
              class="absolute bottom-[22%] right-[14%] h-1.5 w-1.5 rounded-full bg-[#adcbda] opacity-90 shadow-[0_0_14px_#adcbda]"
            />
            <div
              class="relative flex h-full flex-col justify-between border border-[#b3c5ff]/15 bg-[#10131a]/60 p-4 ring-1 ring-inset ring-[#b3c5ff]/5"
            >
              <div class="flex items-start justify-between gap-3">
                <span
                  class="rounded-lg bg-[#0e4e6f]/50 px-2 py-1 text-[10px] font-bold uppercase tracking-wider text-[#b3c5ff]"
                  >Stack</span
                >
                <span class="text-[10px] font-medium text-[#8c90a1]"
                  >live</span
                >
              </div>
              <div class="space-y-2 font-mono text-[11px] leading-relaxed text-[#c2c6d8]/90 sm:text-xs">
                <p class="text-[#99cdf3]">
                  <span class="text-[#8c90a1]">→</span> deploy <span
                    class="text-[#b3c5ff]">production</span
                  >
                </p>
                <p>
                  <span class="text-[#8c90a1]">—</span> api latency <span
                    class="text-[#99cdf3]">42ms</span
                  >
                </p>
                <p>
                  <span class="text-[#8c90a1]">—</span> uptime <span
                    class="text-[#b3c5ff]">99.99%</span
                  >
                </p>
              </div>
              <div
                class="h-1.5 w-full overflow-hidden rounded-full bg-[#32353c]"
              >
                <div
                  class="h-full w-[72%] rounded-full bg-gradient-to-r from-[#b3c5ff] to-[#0066ff]"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>
