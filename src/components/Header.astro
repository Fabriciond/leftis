---
import { asset } from "../utils/base";
---

<header class="print:hidden">
  <nav
    class="nav-bar fixed top-0 z-[999] flex w-full items-center justify-between border-b border-secondary/20 bg-primary/95 px-4 py-3 shadow-[0_0_12px_rgba(164,216,255,0.25)] backdrop-blur-md sm:px-8 sm:py-4"
    aria-label="Navegación principal"
  >
    <div class="flex w-full flex-wrap items-center justify-between gap-4">
      <a
        class="flex items-center text-xl font-semibold text-secondary no-underline transition-opacity hover:opacity-90 md:text-2xl"
        href="#main-content"
      >
        <img
          src={asset("img/logo.png")}
          class="mr-2.5 h-11 w-11 shrink-0 object-contain sm:h-[50px] sm:w-[50px]"
          width="50"
          height="50"
          alt="Leftis"
        />
        <span>Leftis</span>
      </a>
      <button
        id="navToggle"
        class="inline-flex items-center justify-center rounded-lg bg-secondary p-2.5 text-primary transition hover:bg-secondary/90 md:hidden"
        type="button"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Abrir menú"
      >
        <span class="sr-only">Abrir menú principal</span>
        <svg
          class="h-6 w-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
      <div
        id="navbarNav"
        class="hidden w-full flex-col items-center gap-2 border-t border-secondary/20 pt-4 md:flex md:w-auto md:flex-row md:justify-end md:border-0 md:pt-0"
      >
        <ul
          class="flex w-full flex-col items-center gap-2 md:w-auto md:flex-row md:gap-8"
        >
          <li>
            <a
              class="nav-link block rounded px-2 py-2 text-lg font-medium text-secondary no-underline transition hover:border-b-2 hover:border-secondary"
              href="#main-content">Inicio</a>
          </li>
          <li>
            <a
              class="nav-link block rounded px-2 py-2 text-lg font-medium text-secondary no-underline transition hover:border-b-2 hover:border-secondary"
              href="#services">Servicios</a>
          </li>
          <li>
            <a
              class="nav-link block rounded px-2 py-2 text-lg font-medium text-secondary no-underline transition hover:border-b-2 hover:border-secondary"
              href="#contact">Contacto</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>
</header>
