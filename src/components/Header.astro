---

---

<header class="print:hidden">
  <nav
    class="nav-bar fixed top-0 z-[999] w-full border-b border-[#32353c]/20 bg-[#10131a]/60 shadow-2xl shadow-black/20 backdrop-blur-xl"
    aria-label="Navegación principal"
  >
    <div
      class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-4 px-4 py-4 sm:px-8"
    >
      <a
        class="shrink-0 text-xl font-black tracking-tighter text-[#b3c5ff] no-underline transition-opacity hover:opacity-90"
        href="#main-content"
      >
        Leftis Systems
      </a>
      <button
        id="navToggle"
        class="inline-flex items-center justify-center rounded-lg border border-[#424656]/50 bg-[#1d2026]/80 p-2.5 text-[#e1e2eb] transition hover:bg-[#32353c]/50 md:hidden"
        type="button"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Abrir menú"
      >
        <span class="sr-only">Abrir menú principal</span>
        <svg
          class="h-6 w-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
      <div
        id="navbarNav"
        class="hidden w-full flex-col items-stretch gap-4 border-t border-[#32353c]/30 pt-4 md:ml-auto md:flex md:w-auto md:flex-1 md:flex-row md:items-center md:justify-end md:gap-8 md:border-0 md:pt-0"
      >
        <ul
          class="flex w-full flex-col items-center gap-2 md:w-auto md:flex-row md:gap-8"
        >
          <li>
            <a
              class="nav-link block rounded px-2 py-2 text-center text-base font-bold tracking-tight text-[#0066ff] no-underline md:border-b-2 md:border-[#0066ff] md:pb-1"
              href="#main-content">Inicio</a
            >
          </li>
          <li>
            <a
              class="nav-link block rounded px-2 py-2 text-center text-base font-bold tracking-tight text-[#99cdf3] no-underline transition hover:text-[#b3c5ff] md:pb-1"
              href="#services">Servicios</a
            >
          </li>
          <li>
            <a
              class="nav-link block rounded px-2 py-2 text-center text-base font-bold tracking-tight text-[#99cdf3] no-underline transition hover:text-[#b3c5ff] md:pb-1"
              href="#planes">Planes</a
            >
          </li>
        </ul>
        <a
          class="inline-flex min-h-[48px] w-full items-center justify-center rounded-xl bg-[#0066ff] px-6 py-2.5 text-sm font-bold tracking-tight text-[#f8f7ff] no-underline shadow-lg shadow-[#0066ff]/20 transition hover:opacity-90 active:scale-95 md:min-h-0 md:w-auto"
          href="#contact">Contáctanos</a
        >
      </div>
    </div>
  </nav>
</header>
