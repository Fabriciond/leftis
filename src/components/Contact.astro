---
import { asset } from "../utils/base";
---

<section
  id="contact"
  class="scroll-mt-28 bg-primary py-16 sm:py-20"
  aria-labelledby="contact-heading"
>
  <div class="section-inner flex flex-col items-center gap-10">
    <div
      class="flex max-w-2xl flex-col gap-4 text-center"
      data-aos="fade-up"
    >
      <h2
        id="contact-heading"
        class="text-4xl font-extralight tracking-tight text-secondary md:text-6xl lg:text-7xl"
      >
        Contacto
      </h2>
      <p class="text-balance text-lg font-light text-white/90 md:text-xl">
        ¿Listo para comenzar tu próximo proyecto? Trabajemos juntos.
      </p>
    </div>
    <div
      data-aos="fade-up"
      data-aos-delay="100"
      class="w-full max-w-xl rounded-2xl border border-secondary/25 bg-white p-6 shadow-[0_8px_40px_rgba(164,216,255,0.2)] sm:p-10"
    >
      <form
        class="flex flex-col gap-5"
        method="post"
        action="#"
        aria-label="Formulario de contacto"
      >
        <div class="flex flex-col gap-2">
          <label
            for="contact-name"
            class="text-sm font-medium text-primary">Nombre</label>
          <input
            id="contact-name"
            name="name"
            type="text"
            autocomplete="name"
            required
            placeholder="Tu nombre"
            class="min-h-[48px] w-full rounded-lg border border-primary/10 bg-secondary px-4 py-3 text-primary placeholder:text-primary/50 focus:border-secondary focus:ring-2 focus:ring-secondary/50"
          />
        </div>
        <div class="flex flex-col gap-2">
          <label
            for="contact-email"
            class="text-sm font-medium text-primary">Correo</label>
          <input
            id="contact-email"
            name="email"
            type="email"
            autocomplete="email"
            required
            placeholder="correo@ejemplo.com"
            class="min-h-[48px] w-full rounded-lg border border-primary/10 bg-secondary px-4 py-3 text-primary placeholder:text-primary/50 focus:border-secondary focus:ring-2 focus:ring-secondary/50"
          />
        </div>
        <div class="flex flex-col gap-2">
          <label
            for="contact-message"
            class="text-sm font-medium text-primary">Mensaje</label>
          <textarea
            id="contact-message"
            name="message"
            rows="6"
            required
            placeholder="Cuéntanos sobre tu proyecto…"
            class="w-full resize-y rounded-lg border border-primary/10 bg-secondary px-4 py-3 font-sans text-primary placeholder:text-primary/50 focus:border-secondary focus:ring-2 focus:ring-secondary/50"
          ></textarea>
        </div>
        <button
          type="submit"
          class="mt-2 inline-flex min-h-[52px] w-full items-center justify-center gap-3 rounded-lg bg-primary px-6 py-3 text-base font-semibold text-secondary transition hover:bg-primary/90 focus-visible:ring-offset-white sm:w-auto sm:self-center"
        >
          <img
            src={asset("img/enviarForm.png")}
            alt=""
            width="30"
            height="30"
            class="h-7 w-7 object-contain"
            aria-hidden="true"
          />
          <span>Enviar mensaje</span>
        </button>
        <p class="text-center text-xs text-primary/60">
          Al enviar, aceptas ser contactado por Leftis respecto a tu consulta.
        </p>
      </form>
    </div>
  </div>
</section>
