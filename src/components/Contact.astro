---
import { Mail, MapPin } from "@lucide/astro";
import InstagramIcon from "./icons/InstagramIcon.astro";
---

<section
  id="contact"
  class="scroll-mt-28 relative overflow-hidden bg-[#10131a] py-24 sm:py-32"
  aria-labelledby="contact-heading"
>
  <div
    class="pointer-events-none absolute bottom-0 right-0 -z-10 h-[min(600px,90vw)] w-[min(600px,90vw)] translate-x-1/4 translate-y-1/4 rounded-full bg-[#0066ff]/5 blur-[100px]"
    aria-hidden="true"
  />
  <div class="section-inner max-w-5xl">
    <div class="grid gap-16 md:grid-cols-2 md:gap-20">
      <div class="space-y-6" data-aos="fade-up">
        <h2
          id="contact-heading"
          class="text-4xl font-bold tracking-tighter text-[#e1e2eb] md:text-[2.5rem]"
        >
          Iniciemos tu próximo proyecto
        </h2>
        <p class="leading-relaxed text-[#c2c6d8]">
          ¿Tienes una idea en mente? Nuestro equipo está listo para diseñarla y
          construirla. Escríbenos y te respondemos con una propuesta acorde a tu
          alcance.
        </p>
        <div class="space-y-4 pt-4">
     
          <div class="flex items-center gap-4">
            <InstagramIcon class="shrink-0 text-[#b3c5ff]" size={22} />
            <a
              href="https://www.instagram.com/leftissystem/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-[#e1e2eb] no-underline transition hover:text-[#b3c5ff]"
              >@leftissystem</a
            >
          </div>
          <div class="flex items-center gap-4">
            <MapPin
              class="shrink-0 text-[#b3c5ff]"
              size={22}
              stroke-width={2}
              aria-hidden="true"
            />
            <span class="text-[#e1e2eb]">México</span>
          </div>
        </div>
      </div>
      <form
        data-aos="fade-up"
        data-aos-delay="80"
        class="space-y-6 rounded-2xl border border-[#424656]/10 bg-[#191c22]/50 p-8 backdrop-blur-sm"
        method="post"
        action="#"
        aria-label="Formulario de contacto"
      >
        <div class="space-y-2">
          <label
            for="contact-name"
            class="text-xs font-bold uppercase tracking-widest text-[#c2c6d8]"
            >Nombre</label
          >
          <input
            id="contact-name"
            name="name"
            type="text"
            autocomplete="name"
            required
            placeholder="Tu nombre completo"
            class="w-full rounded-t-lg border-0 border-b-2 border-[#424656]/30 bg-[#32353c]/40 px-4 py-3 text-[#e1e2eb] placeholder:text-[#8c90a1] focus:border-[#0066ff] focus:outline-none focus:ring-0"
          />
        </div>
        <div class="space-y-2">
          <label
            for="contact-email"
            class="text-xs font-bold uppercase tracking-widest text-[#c2c6d8]"
            >Correo</label
          >
          <input
            id="contact-email"
            name="email"
            type="email"
            autocomplete="email"
            required
            placeholder="email@ejemplo.com"
            class="w-full rounded-t-lg border-0 border-b-2 border-[#424656]/30 bg-[#32353c]/40 px-4 py-3 text-[#e1e2eb] placeholder:text-[#8c90a1] focus:border-[#0066ff] focus:outline-none focus:ring-0"
          />
        </div>
        <div class="space-y-2">
          <label
            for="contact-message"
            class="text-xs font-bold uppercase tracking-widest text-[#c2c6d8]"
            >Mensaje</label
          >
          <textarea
            id="contact-message"
            name="message"
            rows="4"
            required
            placeholder="Cuéntanos sobre tu proyecto"
            class="w-full resize-none rounded-t-lg border-0 border-b-2 border-[#424656]/30 bg-[#32353c]/40 px-4 py-3 font-sans text-[#e1e2eb] placeholder:text-[#8c90a1] focus:border-[#0066ff] focus:outline-none focus:ring-0"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full rounded-xl bg-[#0066ff] py-4 text-lg font-bold text-[#f8f7ff] transition hover:opacity-90 active:scale-[0.99]"
        >
          Enviar mensaje
        </button>
        <p class="text-center text-xs text-[#8c90a1]">
          Al enviar, aceptas ser contactado por Leftis respecto a tu consulta.
        </p>
      </form>
    </div>
  </div>
</section>
