---
import { asset } from "../utils/base";
---

<section
  id="clientes"
  class="scroll-mt-28 bg-[#10131a] py-16 sm:py-20"
  aria-labelledby="clients-heading"
>
  <div class="section-inner flex max-w-7xl flex-col items-center gap-12 sm:gap-14">
    <div class="flex max-w-3xl flex-col gap-4 text-center" data-aos="fade-up">
      <h2
        id="clients-heading"
        class="text-4xl font-bold tracking-tighter text-[#e1e2eb] md:text-5xl lg:text-6xl"
      >
        Clientes
      </h2>
      <p class="text-lg text-[#c2c6d8] md:text-xl">
        Algunos de los proyectos y marcas con los que hemos trabajado.
      </p>
    </div>
    <div
      class="grid w-full max-w-7xl grid-cols-1 items-center justify-items-center gap-8 sm:grid-cols-2 sm:gap-10 lg:grid-cols-3 lg:gap-12 xl:grid-cols-5 xl:gap-10"
    >
      <div
        class="flex h-40 w-full max-w-[280px] items-center justify-center rounded-2xl bg-[#191c22] p-8 ring-1 ring-[#424656]/40 sm:h-44 md:h-48"
      >
        <img
          src={asset("img/techshop.png")}
          alt="Logo Techshop"
          width="220"
          height="120"
          class="max-h-24 w-auto max-w-full object-contain brightness-110 sm:max-h-28 md:max-h-32"
          loading="lazy"
          decoding="async"
        />
      </div>
      <a
        href="https://a4arquitectos.com.mx"
        target="_blank"
        rel="noopener noreferrer"
        class="flex h-40 w-full max-w-[280px] items-center justify-center rounded-2xl bg-[#191c22] p-8 ring-1 ring-[#424656]/40 transition hover:bg-[#272a31] sm:h-44 md:h-48"
      >
        <img
          src={asset("img/1.png")}
          alt="A4 Arquitectos"
          width="220"
          height="120"
          class="max-h-24 w-auto max-w-full object-contain brightness-110 sm:max-h-28 md:max-h-32"
          loading="lazy"
          decoding="async"
        />
      </a>
      <a
        href="https://casaurbana.com.mx"
        target="_blank"
        rel="noopener noreferrer"
        class="flex h-40 w-full max-w-[280px] items-center justify-center rounded-2xl bg-[#191c22] p-8 ring-1 ring-[#424656]/40 transition hover:bg-[#272a31] sm:h-44 md:h-48"
      >
        <img
          src={asset("img/2.png")}
          alt="Casa Urbana"
          width="220"
          height="120"
          class="max-h-24 w-auto max-w-full object-contain brightness-110 sm:max-h-28 md:max-h-32"
          loading="lazy"
          decoding="async"
        />
      </a>
      <a
        href="https://procapitalmzt.com"
        target="_blank"
        rel="noopener noreferrer"
        class="flex h-40 w-full max-w-[280px] items-center justify-center rounded-2xl bg-[#191c22] p-8 ring-1 ring-[#424656]/40 transition hover:bg-[#272a31] sm:h-44 md:h-48"
      >
        <img
          src={asset("img/3.png")}
          alt="Pro Capital"
          width="220"
          height="120"
          class="max-h-24 w-auto max-w-full object-contain brightness-110 sm:max-h-28 md:max-h-32"
          loading="lazy"
          decoding="async"
        />
      </a>
      <a
        href="https://propescaguaymas.com"
        target="_blank"
        rel="noopener noreferrer"
        class="flex h-40 w-full max-w-[280px] items-center justify-center rounded-2xl bg-[#191c22] p-8 ring-1 ring-[#424656]/40 transition hover:bg-[#272a31] sm:h-44 md:h-48"
      >
        <img
          src={asset("img/propesca.png")}
          alt="Propesca Guaymas"
          width="220"
          height="120"
          class="max-h-24 w-auto max-w-full object-contain brightness-110 sm:max-h-28 md:max-h-32"
          loading="lazy"
          decoding="async"
        />
      </a>
    </div>
  </div>
</section>
