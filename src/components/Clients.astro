---
import { asset } from "../utils/base";
---

<section
  id="clientes"
  class="scroll-mt-28 bg-primary py-16 sm:py-20"
  aria-labelledby="clients-heading"
>
  <div class="section-inner flex flex-col items-center gap-10">
    <div class="flex max-w-2xl flex-col gap-3 text-center" data-aos="fade-up">
      <h2
        id="clients-heading"
        class="text-4xl font-extralight tracking-tight text-secondary md:text-6xl lg:text-7xl"
      >
        Clientes
      </h2>
      <p class="text-lg font-light text-white/90 md:text-xl">
        Algunos de los proyectos y marcas con los que hemos trabajado.
      </p>
    </div>
    <div
      class="grid w-full max-w-5xl grid-cols-1 items-center justify-items-center gap-10 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5"
    >
      <div
        class="flex h-28 w-full max-w-[200px] items-center justify-center rounded-xl bg-secondary/10 p-6 sm:h-32"
      >
        <img
          src={asset("img/techshop.png")}
          alt="Logo Techshop"
          width="150"
          height="80"
          class="max-h-12 w-auto max-w-full object-contain opacity-90"
          loading="lazy"
          decoding="async"
        />
      </div>
      <a
        href="https://a4arquitectos.com.mx"
        target="_blank"
        rel="noopener noreferrer"
        class="flex h-28 w-full max-w-[200px] items-center justify-center rounded-xl bg-secondary/10 p-6 transition hover:bg-secondary/20 sm:h-32"
      >
        <img
          src={asset("img/1.png")}
          alt="A4 Arquitectos"
          width="150"
          height="80"
          class="max-h-12 w-auto max-w-full object-contain"
          loading="lazy"
          decoding="async"
        />
      </a>
      <a
        href="https://casaurbana.com.mx"
        target="_blank"
        rel="noopener noreferrer"
        class="flex h-28 w-full max-w-[200px] items-center justify-center rounded-xl bg-secondary/10 p-6 transition hover:bg-secondary/20 sm:h-32"
      >
        <img
          src={asset("img/2.png")}
          alt="Casa Urbana"
          width="150"
          height="80"
          class="max-h-12 w-auto max-w-full object-contain"
          loading="lazy"
          decoding="async"
        />
      </a>
      <a
        href="https://procapitalmzt.com"
        target="_blank"
        rel="noopener noreferrer"
        class="flex h-28 w-full max-w-[200px] items-center justify-center rounded-xl bg-secondary/10 p-6 transition hover:bg-secondary/20 sm:h-32"
      >
        <img
          src={asset("img/3.png")}
          alt="Pro Capital"
          width="150"
          height="80"
          class="max-h-12 w-auto max-w-full object-contain"
          loading="lazy"
          decoding="async"
        />
      </a>
      <a
        href="https://propescaguaymas.com"
        target="_blank"
        rel="noopener noreferrer"
        class="flex h-28 w-full max-w-[200px] items-center justify-center rounded-xl bg-secondary/10 p-6 transition hover:bg-secondary/20 sm:h-32"
      >
        <img
          src={asset("img/propesca.png")}
          alt="Propesca Guaymas"
          width="150"
          height="80"
          class="max-h-12 w-auto max-w-full object-contain"
          loading="lazy"
          decoding="async"
        />
      </a>
    </div>
  </div>
</section>
