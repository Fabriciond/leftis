---
import "../styles/global.css";
import "aos/dist/aos.css";
import { asset } from "../utils/base";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Leftis — Desarrollo web y software a la medida",
  description =
    "Leftis: desarrollo web, marketing digital y consultoría en México. Landing pages, sistemas para PyME y software empresarial.",
} = Astro.props;

const siteBase = Astro.site ?? new URL("http://localhost");
const canonicalURL = new URL(Astro.url.pathname, siteBase);
const ogImage = new URL(asset("img/logo.png"), siteBase).href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#10131a" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href={asset("img/favicon.ico")} sizes="any" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600;700&display=swap"
      rel="stylesheet"
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="es_MX" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
  </head>
  <body
    class="bg-[#10131a] font-sans leading-relaxed text-[#e1e2eb] antialiased"
  >
    <a class="skip-link" href="#main-content">Saltar al contenido</a>
    <slot />
    <script>
      import { initApp } from "../scripts/client";
      initApp();
    </script>
  </body>
</html>
