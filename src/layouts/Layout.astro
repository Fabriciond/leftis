---
import "../styles/global.css";
import "aos/dist/aos.css";

interface Props {
  title?: string;
}

const { title = "Leftis" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" href={`${import.meta.env.BASE_URL}img/logo.png`} />
    <link
      href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-primary font-sans leading-relaxed text-white">
    <slot />
    <script>
      import { initApp } from "../scripts/client";
      initApp();
    </script>
  </body>
</html>
